{
  "name": "ppap-tab",
  "displayName": "PPAP Tab",
  "description": "Cursor/Copilot-style VS Code inline Tab completion for OpenAI-compatible PPAP endpoints.",
  "version": "0.2.1",
  "publisher": "daishuge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daishuge/vscode-ppap-tab.git"
  },
  "homepage": "https://github.com/daishuge/vscode-ppap-tab#readme",
  "bugs": {
    "url": "https://github.com/daishuge/vscode-ppap-tab/issues"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": false
  },
  "contributes": {
    "commands": [
      {
        "command": "ppapTab.trigger",
        "title": "PPAP Tab: Trigger Inline Completion"
      },
      {
        "command": "ppapTab.toggle",
        "title": "PPAP Tab: Toggle"
      },
      {
        "command": "ppapTab.test",
        "title": "PPAP Tab: Test API"
      },
      {
        "command": "ppapTab.showOutput",
        "title": "PPAP Tab: Show Output"
      }
    ],
    "keybindings": [
      {
        "command": "ppapTab.trigger",
        "key": "alt+\\",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "PPAP Tab",
      "properties": {
        "ppapTab.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable PPAP Tab inline completions."
        },
        "ppapTab.model": {
          "type": "string",
          "default": "gpt-5.3-codex-spark",
          "description": "Model ID for inline completions."
        },
        "ppapTab.baseUrl": {
          "type": "string",
          "default": "http://m.daishuge.win:8317/v1",
          "description": "Fallback OpenAI-compatible API base URL. Environment variable 补全url or PPAP_COMPLETION_URL takes precedence. Do not include /chat/completions."
        },
        "ppapTab.urlEnvName": {
          "type": "string",
          "default": "补全url",
          "description": "Environment variable name for the OpenAI-compatible API base URL."
        },
        "ppapTab.keyEnvName": {
          "type": "string",
          "default": "补全key",
          "description": "Environment variable name for the API key. The key is never written to VS Code settings."
        },
        "ppapTab.secretEnvPath": {
          "type": "string",
          "default": "D:\\codex\\secret\\cliproxy-image-cli.env",
          "description": "Compatibility fallback env file containing CLIPROXY_API_KEY. Prefer the 补全key environment variable."
        },
        "ppapTab.debounceMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay before asking PPAP for a suggestion. Lower values favor responsiveness over request volume."
        },
        "ppapTab.timeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "HTTP request timeout."
        },
        "ppapTab.maxPrefixChars": {
          "type": "number",
          "default": 12000,
          "minimum": 500,
          "maximum": 30000,
          "description": "Maximum characters before the cursor sent as context."
        },
        "ppapTab.maxSuffixChars": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "maximum": 10000,
          "description": "Maximum characters after the cursor sent as context."
        },
        "ppapTab.maxCompletionTokens": {
          "type": "number",
          "default": 256,
          "minimum": 16,
          "maximum": 1024,
          "description": "Maximum completion tokens requested from the model."
        },
        "ppapTab.maxCompletionChars": {
          "type": "number",
          "default": 4000,
          "minimum": 80,
          "maximum": 12000,
          "description": "Maximum inserted characters after cleanup."
        },
        "ppapTab.includeOpenFilesContext": {
          "type": "boolean",
          "default": true,
          "description": "Include snippets from visible/open files for Cursor-like context."
        },
        "ppapTab.maxOpenFiles": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 12,
          "description": "Maximum non-active open files sent as context."
        },
        "ppapTab.maxOpenFileChars": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "maximum": 8000,
          "description": "Maximum characters per open-file context snippet."
        },
        "ppapTab.maxCacheEntries": {
          "type": "number",
          "default": 250,
          "minimum": 0,
          "maximum": 1000,
          "description": "Maximum recent inline completions cached by cursor context."
        },
        "ppapTab.typingReuseMs": {
          "type": "number",
          "default": 30000,
          "minimum": 0,
          "maximum": 300000,
          "description": "How long PPAP Tab reuses the currently shown suggestion while the user types into it."
        },
        "ppapTab.autoTriggerAfterEdit": {
          "type": "boolean",
          "default": true,
          "description": "Actively trigger inline suggestions after edits, instead of relying only on VS Code's automatic provider scheduling."
        },
        "ppapTab.autoTriggerAfterCursorMove": {
          "type": "boolean",
          "default": true,
          "description": "Actively trigger inline suggestions after cursor movement."
        },
        "ppapTab.autoTriggerDelayMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay before active inline suggestion triggers."
        },
        "ppapTab.temperature": {
          "type": "number",
          "default": 0.05,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature."
        },
        "ppapTab.excludePatterns": {
          "type": "array",
          "default": [
            "**/.git/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/*.lock",
            "**/*.log",
            "**/.env",
            "**/secret/**",
            "**/secrets/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob-like substrings where PPAP Tab is disabled."
        }
      }
    }
  }
}
