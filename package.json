{
  "name": "ppap-tab",
  "displayName": "PPAP Tab",
  "description": "Cursor/Copilot-style VS Code inline Tab completion for OpenAI-compatible PPAP endpoints.",
  "version": "0.2.4",
  "publisher": "daishuge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daishuge/vscode-ppap-tab.git"
  },
  "homepage": "https://github.com/daishuge/vscode-ppap-tab#readme",
  "bugs": {
    "url": "https://github.com/daishuge/vscode-ppap-tab/issues"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": false
  },
  "contributes": {
    "commands": [
      {
        "command": "ppapTab.trigger",
        "title": "PPAP Tab: Trigger Inline Completion"
      },
      {
        "command": "ppapTab.toggle",
        "title": "PPAP Tab: Toggle"
      },
      {
        "command": "ppapTab.test",
        "title": "PPAP Tab: Test API"
      },
      {
        "command": "ppapTab.showOutput",
        "title": "PPAP Tab: Show Output"
      },
      {
        "command": "ppapTab.typeAndTrigger",
        "title": "PPAP Tab: Type And Trigger Inline Completion"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "title": "PPAP Tab: Run Editor Command And Trigger Inline Completion"
      },
      {
        "command": "ppapTab.copyAndTrigger",
        "title": "PPAP Tab: Copy And Trigger Inline Completion"
      },
      {
        "command": "ppapTab.cutAndTrigger",
        "title": "PPAP Tab: Cut And Trigger Inline Completion"
      },
      {
        "command": "ppapTab.pasteAndTrigger",
        "title": "PPAP Tab: Paste And Trigger Inline Completion"
      },
      {
        "command": "ppapTab.undoAndTrigger",
        "title": "PPAP Tab: Undo And Trigger Inline Completion"
      },
      {
        "command": "ppapTab.redoAndTrigger",
        "title": "PPAP Tab: Redo And Trigger Inline Completion"
      }
    ],
    "keybindings": [
      {
        "command": "ppapTab.trigger",
        "key": "alt+\\",
        "when": "editorTextFocus"
      },
      {
        "command": "ppapTab.typeAndTrigger",
        "key": "space",
        "args": {
          "text": " "
        },
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.typeAndTrigger",
        "key": "enter",
        "args": {
          "text": "\n"
        },
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "backspace",
        "args": {
          "command": "deleteLeft",
          "reason": "backspace"
        },
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "delete",
        "args": {
          "command": "deleteRight",
          "reason": "delete"
        },
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "ctrl+backspace",
        "args": {
          "command": "deleteWordLeft",
          "reason": "ctrl+backspace"
        },
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "ctrl+delete",
        "args": {
          "command": "deleteWordRight",
          "reason": "ctrl+delete"
        },
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.pasteAndTrigger",
        "key": "ctrl+v",
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.copyAndTrigger",
        "key": "ctrl+c",
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.cutAndTrigger",
        "key": "ctrl+x",
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.undoAndTrigger",
        "key": "ctrl+z",
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.redoAndTrigger",
        "key": "ctrl+y",
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.redoAndTrigger",
        "key": "ctrl+shift+z",
        "when": "editorTextFocus && !editorReadonly && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "left",
        "args": {
          "command": "cursorMove",
          "reason": "left",
          "args": {
            "to": "left",
            "by": "character",
            "value": 1
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "right",
        "args": {
          "command": "cursorMove",
          "reason": "right",
          "args": {
            "to": "right",
            "by": "character",
            "value": 1
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "up",
        "args": {
          "command": "cursorMove",
          "reason": "up",
          "args": {
            "to": "up",
            "by": "line",
            "value": 1
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "down",
        "args": {
          "command": "cursorMove",
          "reason": "down",
          "args": {
            "to": "down",
            "by": "line",
            "value": 1
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "shift+left",
        "args": {
          "command": "cursorMove",
          "reason": "shift+left",
          "args": {
            "to": "left",
            "by": "character",
            "value": 1,
            "select": true
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "shift+right",
        "args": {
          "command": "cursorMove",
          "reason": "shift+right",
          "args": {
            "to": "right",
            "by": "character",
            "value": 1,
            "select": true
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "shift+up",
        "args": {
          "command": "cursorMove",
          "reason": "shift+up",
          "args": {
            "to": "up",
            "by": "line",
            "value": 1,
            "select": true
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "shift+down",
        "args": {
          "command": "cursorMove",
          "reason": "shift+down",
          "args": {
            "to": "down",
            "by": "line",
            "value": 1,
            "select": true
          }
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "home",
        "args": {
          "command": "cursorHome",
          "reason": "home"
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "end",
        "args": {
          "command": "cursorEnd",
          "reason": "end"
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "pageup",
        "args": {
          "command": "cursorPageUp",
          "reason": "pageup"
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      },
      {
        "command": "ppapTab.editorCommandAndTrigger",
        "key": "pagedown",
        "args": {
          "command": "cursorPageDown",
          "reason": "pagedown"
        },
        "when": "editorTextFocus && !suggestWidgetVisible && !renameInputVisible"
      }
    ],
    "configuration": {
      "title": "PPAP Tab",
      "properties": {
        "ppapTab.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable PPAP Tab inline completions."
        },
        "ppapTab.model": {
          "type": "string",
          "default": "your-code-model",
          "description": "Model ID for inline completions."
        },
        "ppapTab.baseUrl": {
          "type": "string",
          "default": "https://your-openai-compatible-host/v1",
          "description": "Fallback OpenAI-compatible API base URL. Environment variable PPAP_COMPLETION_URL or 补全url takes precedence. Do not include /chat/completions."
        },
        "ppapTab.urlEnvName": {
          "type": "string",
          "default": "PPAP_COMPLETION_URL",
          "description": "Environment variable name for the OpenAI-compatible API base URL."
        },
        "ppapTab.keyEnvName": {
          "type": "string",
          "default": "PPAP_COMPLETION_KEY",
          "description": "Environment variable name for the API key. The key is never written to VS Code settings."
        },
        "ppapTab.secretEnvPath": {
          "type": "string",
          "default": "D:\\codex\\secret\\cliproxy-image-cli.env",
          "description": "Compatibility fallback env file containing CLIPROXY_API_KEY. Prefer the 补全key environment variable."
        },
        "ppapTab.debounceMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay before asking PPAP for a suggestion. Lower values favor responsiveness over request volume."
        },
        "ppapTab.timeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "HTTP request timeout."
        },
        "ppapTab.maxPrefixChars": {
          "type": "number",
          "default": 12000,
          "minimum": 500,
          "maximum": 30000,
          "description": "Maximum characters before the cursor sent as context."
        },
        "ppapTab.maxSuffixChars": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "maximum": 10000,
          "description": "Maximum characters after the cursor sent as context."
        },
        "ppapTab.maxCompletionTokens": {
          "type": "number",
          "default": 256,
          "minimum": 16,
          "maximum": 1024,
          "description": "Maximum completion tokens requested from the model."
        },
        "ppapTab.maxCompletionChars": {
          "type": "number",
          "default": 4000,
          "minimum": 80,
          "maximum": 12000,
          "description": "Maximum inserted characters after cleanup."
        },
        "ppapTab.includeOpenFilesContext": {
          "type": "boolean",
          "default": true,
          "description": "Include snippets from visible/open files for Cursor-like context."
        },
        "ppapTab.maxOpenFiles": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 12,
          "description": "Maximum non-active open files sent as context."
        },
        "ppapTab.maxOpenFileChars": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "maximum": 8000,
          "description": "Maximum characters per open-file context snippet."
        },
        "ppapTab.maxCacheEntries": {
          "type": "number",
          "default": 250,
          "minimum": 0,
          "maximum": 1000,
          "description": "Maximum recent inline completions cached by cursor context."
        },
        "ppapTab.typingReuseMs": {
          "type": "number",
          "default": 30000,
          "minimum": 0,
          "maximum": 300000,
          "description": "How long PPAP Tab reuses the currently shown suggestion while the user types into it."
        },
        "ppapTab.autoTriggerAfterEdit": {
          "type": "boolean",
          "default": true,
          "description": "Actively trigger inline suggestions after edits, instead of relying only on VS Code's automatic provider scheduling."
        },
        "ppapTab.autoTriggerAfterCursorMove": {
          "type": "boolean",
          "default": true,
          "description": "Actively trigger inline suggestions after cursor movement."
        },
        "ppapTab.autoTriggerDelayMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay before active inline suggestion triggers."
        },
        "ppapTab.aggressiveAutoTrigger": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions on nearly every editor event and wrapped editor command."
        },
        "ppapTab.autoTriggerAfterActiveEditorChange": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions after switching active editors."
        },
        "ppapTab.autoTriggerAfterVisibleEditorsChange": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions after visible editor layout changes."
        },
        "ppapTab.autoTriggerAfterVisibleRangeChange": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions after scrolling or visible range changes."
        },
        "ppapTab.autoTriggerAfterDocumentOpen": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions after opening a text document."
        },
        "ppapTab.autoTriggerAfterDocumentSave": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions after saving the active document."
        },
        "ppapTab.autoTriggerAfterClipboardCommand": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions after wrapped copy, cut, paste, undo, and redo commands."
        },
        "ppapTab.autoTriggerAfterWindowFocus": {
          "type": "boolean",
          "default": true,
          "description": "Trigger inline suggestions when the VS Code window regains focus."
        },
        "ppapTab.discardPendingOnEdit": {
          "type": "boolean",
          "default": true,
          "description": "Abort and discard pending completion requests for the active document whenever the user changes its text."
        },
        "ppapTab.autoTriggerBurstCount": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of inline-suggestion trigger attempts scheduled for each editor event."
        },
        "ppapTab.autoTriggerBurstIntervalMs": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay between burst trigger attempts."
        },
        "ppapTab.maxScheduledTriggers": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum queued trigger timers allowed at once."
        },
        "ppapTab.temperature": {
          "type": "number",
          "default": 0.05,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature."
        },
        "ppapTab.excludePatterns": {
          "type": "array",
          "default": [
            "**/.git/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/*.lock",
            "**/*.log",
            "**/.env",
            "**/secret/**",
            "**/secrets/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob-like substrings where PPAP Tab is disabled."
        }
      }
    }
  }
}
